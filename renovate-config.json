{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for Caracal Lynx repos. Consumers extend it with: \"extends\": [\"local>caracal-lynx/.github:renovate-config\"]",

  "extends": ["config:recommended"],
  "timezone": "Europe/London",
  "schedule": ["before 9am on monday"],
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,

  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "labels": ["vulnerability", "dependencies"]
  },

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"],
    "automerge": true
  },

  "packageRules": [
    {
      "description": "Group all @types/* updates together; auto-merge non-major",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "type definitions",
      "automerge": true,
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "description": "Group dev dependencies; auto-merge non-major",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies",
      "automerge": true
    },
    {
      "description": "Group GitHub Actions updates; auto-merge non-major",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "github actions",
      "automerge": true
    },
    {
      "description": "Major bumps always get their own PR and require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Runtime dependencies (anything that ships to users) never auto-merge — manual review enforced",
      "matchDepTypes": ["dependencies"],
      "automerge": false
    }
  ]
}
